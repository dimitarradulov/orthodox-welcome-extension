{
  "manifest_version": 3,
  "name": "Orthodox Welcome",
  "description": "Orthodox Welcome replaces your new tab with an inspiring Orthodox-themed page.",
  "version": "1",
  "icons": {
    "16": "./images/icon16.png",
    "32": "./images/icon32.png",
    "48": "./images/icon48.png",
    "128": "./images/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "./pages/orthodox-welcome.html"
  },
  "background": {
    "service_worker": "./background.js",
    "type": "module"
  },
  "permissions": ["storage", "alarms"]
}
